{
  "productName": "Pomodoroz",
  "appId": "com.cjdduarte.pomodoroz",
  "copyright": "Copyright © 2026 ${author}",
  "afterSign": "app/electron/electron-builder/afterSign.js",
  "publish": [
    {
      "provider": "github",
      "owner": "cjdduarte",
      "repo": "pomodoroz",
      "releaseType": "release"
    }
  ],
  "files": ["build"],
  "mac": {
    "artifactName": "Pomodoroz-v${version}-mac-${arch}.${ext}",
    "category": "public.app-category.productivity",
    "icon": "app/electron/build/assets/logo-dark@2x.png"
  },
  "win": {
    "target": [
      {
        "target": "portable"
      },
      {
        "target": "nsis"
      }
    ],
    "icon": "app/electron/build/assets/logo-dark.ico"
  },
  "portable": {
    "artifactName": "Pomodoroz-v${version}-win-${arch}-portable.${ext}"
  },
  "nsis": {
    "artifactName": "Pomodoroz-v${version}-win-${arch}-setup.${ext}",
    "include": "app/electron/electron-builder/installer.nsh",
    "shortcutName": "Pomodoroz",
    "uninstallDisplayName": "Pomodoroz",
    "createStartMenuShortcut": true,
    "createDesktopShortcut": true
  },
  "linux": {
    "artifactName": "Pomodoroz-v${version}-linux-${arch}.${ext}",
    "target": ["AppImage", "deb", "rpm"],
    "icon": "app/electron/build/assets/",
    "category": "Utility"
  },
  "snap": {
    "category": "Utility"
  }
}
