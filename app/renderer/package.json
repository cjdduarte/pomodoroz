{
  "name": "@pomodoroz/renderer",
  "version": "26.4.18",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Carlos Duarte",
    "email": "cjdduarte@gmail.com",
    "url": "https://github.com/cjdduarte"
  },
  "description": "Pomodoro timer with task management and statistics for Windows, Mac, and Linux.",
  "homepage": "./",
  "scripts": {
    "clean": "rimraf build/",
    "prebuild": "node ../../scripts/pnpmw.mjs clean && copyfiles -u 5 \"../../src/assets/logos/*\" ../electron/src/assets",
    "build": "vite build",
    "postbuild": "copyfiles -u 1 \"build/**/*\" ../electron/build",
    "dev:renderer": "vite --host localhost --port 3000 --strictPort",
    "start": "node ../../scripts/pnpmw.mjs dev:renderer",
    "start:vite": "node ../../scripts/pnpmw.mjs dev:renderer",
    "lint": "node ../../scripts/pnpmw.mjs --dir ../.. exec eslint --config app/renderer/eslint.config.mjs \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "babelMacros": {
    "styledComponents": {
      "fileName": false,
      "pure": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.29.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
