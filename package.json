{
  "name": "root",
  "private": true,
  "version": "26.4.7",
  "workspaces": [
    "app/*"
  ],
  "scripts": {
    "prepare": "cd .. && ./pomodoroz/node_modules/.bin/husky pomodoroz/.husky",
    "commit": "git-cz",
    "dev:renderer": "lerna run dev:renderer --stream",
    "dev:main": "lerna run dev:main --stream",
    "dev:main:vite": "lerna run dev:main:vite --stream",
    "dev:app": "cross-env ELECTRON_ENABLE_LOGGING=1 lerna run start:vite --parallel --stream",
    "dev:app:vite": "cross-env ELECTRON_ENABLE_LOGGING=1 lerna run start:vite --parallel --stream",
    "prebuild": "yarn workspace @pomodoroz/shareables run prepare && yarn workspace pomodoroz run prepare",
    "lerna": "lerna",
    "build": "lerna run build --parallel --stream",
    "build:mwl": "yarn build && lerna run build:mwl --stream",
    "build:dir": "yarn build && lerna run build:dir --stream",
    "build:win": "yarn build && lerna run build:win --stream",
    "build:mac": "yarn build && lerna run build:mac --stream",
    "build:linux": "yarn build && lerna run build:linux --stream",
    "build:snap": "yarn build && lerna run build:snap --stream",
    "release:mw": "yarn build && lerna run release:mw --stream",
    "release": "yarn build && lerna run release --stream",
    "version:sync": "node ../scripts/version-sync.mjs",
    "clean": "lerna exec -- rimraf build/ dist/",
    "format": "prettier --write .",
    "lint": "yarn workspace @pomodoroz/renderer run lint && yarn workspace pomodoroz run lint && yarn workspace @pomodoroz/shareables run lint"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "25.5.2",
    "commitizen": "^4.1.2",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "6.0.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {}
}
