{
  "name": "pomodoroz",
  "private": true,
  "version": "26.5.3",
  "packageManager": "pnpm@10.33.3",
  "license": "MIT",
  "author": {
    "name": "Carlos Duarte",
    "email": "cjdduarte@gmail.com",
    "url": "https://github.com/cjdduarte"
  },
  "repository": "https://github.com/cjdduarte/pomodoroz",
  "description": "Pomodoro timer with task management and statistics for Windows, Mac, and Linux.",
  "scripts": {
    "prepare": "husky .husky",
    "commit": "git-cz",
    "build:renderer": "node ./node_modules/vite/bin/vite.js build --config app/renderer/vite.config.ts",
    "typecheck:renderer": "node ./node_modules/typescript/bin/tsc --noEmit -p app/renderer/tsconfig.json",
    "build:tauri": "node ./scripts/pnpmw.mjs tauri build --no-bundle",
    "lint:renderer": "node ./scripts/pnpmw.mjs exec eslint --config app/renderer/eslint.config.mjs \"src/**/*.{js,jsx,ts,tsx}\"",
    "dev:app": "node ./scripts/pnpmw.mjs tauri dev",
    "build": "node ./scripts/pnpmw.mjs build:renderer",
    "version:sync": "node scripts/version-sync.mjs",
    "release:tag": "./scripts/release.sh",
    "release:tag:dry": "./scripts/release.sh --dry-run",
    "release:tag:skip-validate": "./scripts/release.sh --skip-validate",
    "release:tag:ps": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "clean": "rimraf app/renderer/build src-tauri/target",
    "format": "prettier --write .",
    "lint": "node ./scripts/pnpmw.mjs lint:renderer",
    "test": "vitest",
    "test:run": "vitest run",
    "tauri": "tauri"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "5.7.2",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/cli": "2.11.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.0",
    "commitizen": "^4.1.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.3",
    "tslib": "^2.8.1",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/is-prop-valid": "^1.4.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tauri-apps/plugin-autostart": "2.5.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "i18next": "^26.0.9",
    "lodash.debounce": "^4.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.6",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router": "7.15.0",
    "react-textarea-autosize": "^8.5.9",
    "redux": "^5.0.1",
    "styled-components": "^6.4.1",
    "uuid": "^14.0.0"
  }
}
