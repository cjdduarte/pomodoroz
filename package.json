{
  "name": "root",
  "private": true,
  "version": "26.4.15",
  "workspaces": [
    "app/*"
  ],
  "scripts": {
    "prepare": "husky .husky",
    "commit": "git-cz",
    "dev:renderer": "lerna run dev:renderer --stream",
    "dev:main": "lerna run dev:main --stream",
    "dev:main:vite": "lerna run dev:main:vite --stream",
    "dev:app": "cross-env ELECTRON_ENABLE_LOGGING=1 lerna run start:vite --parallel --stream",
    "dev:app:vite": "cross-env ELECTRON_ENABLE_LOGGING=1 lerna run start:vite --parallel --stream",
    "prebuild": "pnpm --filter @pomodoroz/shareables run prepare && pnpm --filter pomodoroz run prepare",
    "lerna": "lerna",
    "build": "lerna run build --parallel --stream",
    "build:mwl": "pnpm build && lerna run build:mwl --stream",
    "build:dir": "pnpm build && lerna run build:dir --stream",
    "build:win": "pnpm build && lerna run build:win --stream",
    "build:mac": "pnpm build && lerna run build:mac --stream",
    "build:linux": "pnpm build && lerna run build:linux --stream",
    "build:snap": "pnpm build && lerna run build:snap --stream",
    "release:mw": "pnpm build && lerna run release:mw --stream",
    "release": "pnpm build && lerna run release --stream",
    "version:sync": "node scripts/version-sync.mjs",
    "release:tag": "./scripts/release.sh",
    "release:tag:dry": "./scripts/release.sh --dry-run",
    "release:tag:skip-validate": "./scripts/release.sh --skip-validate",
    "release:tag:ps": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "clean": "lerna exec -- rimraf build/ dist/",
    "format": "prettier --write .",
    "lint": "pnpm --filter @pomodoroz/renderer run lint && pnpm --filter pomodoroz run lint && pnpm --filter @pomodoroz/shareables run lint",
    "tauri": "tauri"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "25.5.2",
    "commitizen": "^4.1.2",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "6.0.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {}
}
