{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pomodoroz",
  "version": "26.4.36",
  "identifier": "com.cjdduarte.pomodoroz",
  "build": {
    "frontendDist": "../app/renderer/build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --config app/renderer/vite.config.ts --host localhost --port 3000 --strictPort",
    "beforeBuildCommand": "node ./scripts/pnpmw.mjs build:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Pomodoroz",
        "width": 340,
        "height": 470,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; media-src 'self' data:; connect-src 'self' http://ipc.localhost ipc: ipc://localhost; object-src 'none'; base-uri 'self'; form-action 'none'; frame-src 'none'; worker-src 'none'",
      "devCsp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; media-src 'self' data:; connect-src 'self' http://localhost:3000 ws://localhost:3000 http://ipc.localhost ipc: ipc://localhost; object-src 'none'; base-uri 'self'; form-action 'none'; frame-src 'none'; worker-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "desktopTemplate": "packaging/linux/desktop-template.hbs"
      },
      "rpm": {
        "desktopTemplate": "packaging/linux/desktop-template.hbs"
      }
    },
    "windows": {
      "nsis": {
        "startMenuFolder": "Pomodoroz"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cjdduarte/pomodoroz/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDMjc4MjMxODRCN0Y3NzMKUldSejk3ZUVNWUluVEtlRDJkMjBJRmxWL0V4bmVVazZ5dWFrTkFXUkl5eUtweGl0dE01V05yWGcK"
    }
  }
}
