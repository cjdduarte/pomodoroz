{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pomodoroz",
  "version": "26.4.15",
  "identifier": "com.cjdduarte.pomodoroz",
  "build": {
    "frontendDist": "../app/renderer/build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "node ./scripts/pnpmw.mjs --filter @pomodoroz/renderer run dev:renderer",
    "beforeBuildCommand": "node ./scripts/pnpmw.mjs --filter @pomodoroz/renderer run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pomodoroz",
        "width": 340,
        "height": 470,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "startMenuFolder": "Pomodoroz"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cjdduarte/pomodoroz/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY"
    }
  }
}
